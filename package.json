    "multer": "^2.1.1",
    "mysql2": "^3.22.4",
    "nodemailer": "^8.0.10",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5"
  }
